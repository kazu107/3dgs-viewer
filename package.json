{
  "name": "3dgs-viewer",
  "version": "1.0.0",
  "description": "広域3D Gaussian Splattingシーンをフライカメラで自由に探索できるWebビューア (Spark 2.x + Three.js + Cloudflare R2 + Heroku)",
  "private": true,
  "type": "module",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "vite",
    "prebuild": "node scripts/clean-dist.js",
    "build": "vite build",
    "start": "node server/index.js",
    "preview": "npm run build && node server/index.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1079.0",
    "@aws-sdk/lib-storage": "^3.1079.0",
    "@aws-sdk/s3-request-presigner": "^3.1079.0",
    "compression": "^1.7.5",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@sparkjsdev/spark": "^2.1.0",
    "three": "^0.180.0",
    "vite": "^6.3.5"
  }
}
