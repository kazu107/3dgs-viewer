# Cloudflare R2 の接続情報(ローカル開発用。Heroku では config vars に設定する)
# Cloudflareダッシュボード → R2 → 概要 右側の「アカウントID」
R2_ACCOUNT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# R2 → API → R2 APIトークンを管理 → 「オブジェクト読み取り専用」トークンを作成
R2_ACCESS_KEY_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
R2_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# シーンファイルを置くバケット名
R2_BUCKET=3dgs-scenes

# (任意) バケット内のこのプレフィックス配下だけを公開する (例: scenes/)
R2_PREFIX=

# (任意) presigned URL の有効期限(秒)。デフォルト3600、最大604800
R2_URL_EXPIRES=3600

# (任意) カスタムドメイン/公開バケットで配信する場合のベースURL
# 設定すると presigned URL の代わりに公開URLを返す
# チャンク分割された .rad (build-lod --rad-chunked) を使う場合はこちらが必須
R2_PUBLIC_BASE_URL=
